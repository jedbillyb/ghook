# Discord webhook URL (from channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# GitHub webhook secret (set the same value when creating the webhook on GitHub)
GITHUB_WEBHOOK_SECRET=your_random_secret_here

# Port the server listens on
PORT=3000

# Whether to forward notifications for private repositories.
# Private repos are skipped by default. Set to "true" to opt in.
NOTIFY_PRIVATE_REPOS=false
