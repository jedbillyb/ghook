# Discord webhook URL (from channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# GitHub webhook secret (set the same value when creating the webhook on GitHub)
GITHUB_WEBHOOK_SECRET=your_random_secret_here

# Port the server listens on
PORT=3000

# Whether to forward notifications for private repositories.
# Private repos are skipped by default. Set to "true" to opt in.
NOTIFY_PRIVATE_REPOS=false

# Discord rendering uses Components V2 by default.
# Uncomment and set to "true" to fall back to classic embeds. Useful while
# Components V2 is still server-gated by Discord and not yet available on
# the server hosting your webhook (V2 messages fail silently otherwise).
# DISCORD_LEGACY_EMBEDS=true

# Footer text shown at the bottom of each message. Override this when
# self-hosting to point users to your own fork. WEBHOOK_FOOTER_URL controls
# the link target rendered in Components V2 mode.
# WEBHOOK_FOOTER=github.com/jedbillyb/ghook
# WEBHOOK_FOOTER_URL=https://github.com/jedbillyb/ghook
