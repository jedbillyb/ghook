# Discord webhook URL (from channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# GitHub webhook secret (set the same value when creating the webhook on GitHub)
GITHUB_WEBHOOK_SECRET=your_random_secret_here

# Port the server listens on
PORT=3000

# Whether to forward notifications for private repositories.
# Private repos are skipped by default. Set to "true" to opt in.
NOTIFY_PRIVATE_REPOS=false

# Discord rendering uses Components V2 by default.
# Uncomment and set to "true" to fall back to classic embeds. Useful while
# Components V2 is still server-gated by Discord and not yet available on
# the server hosting your webhook (V2 messages fail silently otherwise).
# DISCORD_LEGACY_EMBEDS=true

# Footer text shown at the bottom of each message. Override this when
# self-hosting to point users to your own fork. WEBHOOK_FOOTER_URL controls
# the link target rendered in Components V2 mode.
# WEBHOOK_FOOTER=github.com/jedbillyb/ghook
# WEBHOOK_FOOTER_URL=https://github.com/jedbillyb/ghook

# Comma-separated list of GitHub event names to drop entirely.
# Example: silence stars and forks.
# IGNORED_EVENTS=watch,fork

# Comma-separated list of branch name patterns. When set, push/create/delete
# events whose branch does not match any pattern are dropped. Tag refs always
# pass through. "*" matches a single path segment, so "release/*" matches
# "release/v1" but not "release/v1/hotfix".
# BRANCH_FILTER=main,develop,release/*

# Multi-webhook routing (optional). Define extra webhooks as
# DISCORD_WEBHOOK_<NAME>, then map GitHub events to them via ROUTES.
# Rules are evaluated left to right; first match wins. Events with no
# matching rule fall back to DISCORD_WEBHOOK_URL.
# DISCORD_WEBHOOK_RELEASES=https://discord.com/api/webhooks/.../...
# DISCORD_WEBHOOK_CI=https://discord.com/api/webhooks/.../...
# DISCORD_WEBHOOK_ISSUES=https://discord.com/api/webhooks/.../...
# ROUTES=release:RELEASES,workflow_run:CI,issues:ISSUES,issue_comment:ISSUES

# Message language. Defaults to "en". Supported values: "en", "fr".
# Only the static strings ghook itself renders (titles, field labels,
# statuses) are translated — commit messages, issue titles and other
# user-authored content are always passed through unchanged.
# LOCALE=fr
